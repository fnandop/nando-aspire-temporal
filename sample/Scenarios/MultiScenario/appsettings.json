{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Aspire.Hosting.Dcp": "Warning"
    }
  },

  // Select scenario: DevServer, DevServerCustomPorts, FullContainerStack, TemporalCloud, MinimalWorkerOnly
  "Scenario": "DevServer",

  // Image versions (optional)
  "TEMPORAL_VERSION": "latest",
  "TEMPORAL_ADMINTOOLS_VERSION": "latest",
  "TEMPORAL_UI_VERSION": "latest",

  // Temporal Cloud parameters (required when Scenario = "TemporalCloud")
  "Parameters": {
    "temporal-server-endpoint": "your-namespace.tmprl.cloud:7233",
    "temporal-domain": "your-namespace"
  }
}
